# ============================================================
# 2026 世界杯冠军预测系统 — 环境变量配置示例
# 复制为 .env 并填入真实值（不要提交 .env 到版本控制）
# ============================================================

# ── LLM API 配置 ──
# 智谱 AI (GLM)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_MODEL=glm-4-flash

# ── 足球数据 API ──
FOOTBALL_DATA_API=
FOOTBALL_DATA_API_KEY=
API_FOOTBALL=
API_FOOTBALL_KEY=
APISPORTS_KEY=
API_FOOTBALL_MAX_DAILY_CALLS=100

# ── 应用配置 ──
APP_NAME="World Cup Prediction API"
APP_VERSION="1.0.0"
DEBUG=False

# ── 服务器配置 ──
HOST=0.0.0.0
PORT=8001

# ── 数据库配置 ──
DATABASE_URL="sqlite:///./worldcup.db"

# ── 部署配置 ──
# 前端通过此变量连接后端（Docker 内部用 http://backend:8001）
BACKEND_URL=http://localhost:8001
# CORS 允许的域名，逗号分隔；开发环境用 *
ALLOWED_ORIGINS=*
# 运行环境：development / production
ENVIRONMENT=development

# ── 模型配置 ──
# PyTorch 模型权重路径（相对于项目根目录或绝对路径）
MODEL_PATH=models/feature_network_v2_latest.pth

# ── 调度器配置 ──
# 是否启用 APScheduler 定时任务（多实例部署时只在一个实例启用）
ENABLE_SCHEDULER=true
