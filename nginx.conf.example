# ============================================================
# 2026 世界杯冠军预测系统 — Nginx 反向代理配置示例
# 用法：
#   1. 复制为 /etc/nginx/sites-available/worldcup.conf
#   2. ln -s /etc/nginx/sites-available/worldcup.conf /etc/nginx/sites-enabled/
#   3. 修改 server_name 为实际域名
#   4. nginx -t && systemctl reload nginx
#
# HTTPS：使用 certbot 自动配置 SSL
#   certbot --nginx -d your-domain.com
# ============================================================

server {
    listen 80;
    server_name your-domain.com;  # ← 替换为实际域名

    # 前端 Streamlit
    location / {
        proxy_pass http://127.0.0.1:8501;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    # 后端 API（可选：通过同域名代理，前端 BACKEND_URL 改为 /api）
    # location /api/ {
    #     proxy_pass http://127.0.0.1:8001/api/;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #     proxy_set_header X-Forwarded-Proto $scheme;
    # }
}
